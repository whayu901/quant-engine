# Qual Engine Environment Configuration
# Copy this file to .env and update with your actual values

# ====================
# Application Settings
# ====================
APP_NAME="Qual Engine"
APP_ENV=development  # development, staging, production
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
API_VERSION=v1

# ====================
# Database Configuration
# ====================
DATABASE_URL=sqlite:///./qual_engine.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/qualengine

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# ====================
# Redis Configuration
# ====================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ====================
# Celery Configuration
# ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# ====================
# AI/LLM Configuration
# ====================
# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=4000
ANTHROPIC_TEMPERATURE=0.7

# OpenAI (optional alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Local LLM (for development/testing)
USE_MOCK_LLM=true

# ====================
# Authentication & Security
# ====================
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# ====================
# CORS Configuration
# ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept

# ====================
# File Storage
# ====================
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=.txt,.pdf,.docx,.csv,.json,.mp3,.mp4,.wav,.jpg,.png

# S3 Configuration (for production)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=qual-engine-storage
AWS_S3_REGION=ap-southeast-1
AWS_S3_ENDPOINT_URL=  # For S3-compatible services

# ====================
# Email Configuration
# ====================
EMAIL_ENABLED=false
EMAIL_FROM_NAME="Qual Engine"
EMAIL_FROM_ADDRESS=noreply@qualengine.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ====================
# Rate Limiting
# ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/3

# ====================
# Monitoring & Logging
# ====================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH=./logs/app.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Prometheus Metrics
METRICS_ENABLED=false
METRICS_PORT=9090

# ====================
# SEA Market Configuration
# ====================
DEFAULT_LANGUAGE=en  # en, id, ms, th, vi, tl
SUPPORTED_LANGUAGES=en,id,ms,th,vi,tl
DEFAULT_CURRENCY=USD  # USD, SGD, IDR, MYR, THB, PHP, VND
DEFAULT_TIMEZONE=Asia/Singapore

# ====================
# Enterprise Features
# ====================
ENABLE_WHITE_LABEL=true
ENABLE_AUDIT_LOGGING=true
ENABLE_CUSTOM_FIELDS=true
ENABLE_DATA_EXPORT=true
ENABLE_INTEGRATIONS=true

# Audit Log Settings
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_CLEANUP_ENABLED=true

# ====================
# Third-Party Integrations
# ====================
# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Microsoft Teams
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# Google Services
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment Gateways (SEA)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# GrabPay (Regional)
GRABPAY_CLIENT_ID=
GRABPAY_CLIENT_SECRET=

# ====================
# WebSocket Configuration
# ====================
WS_MESSAGE_QUEUE_SIZE=100
WS_HEARTBEAT_INTERVAL=30
WS_CLIENT_TIMEOUT=60

# ====================
# Performance Tuning
# ====================
# API Settings
API_TIMEOUT_SECONDS=30
API_MAX_REQUEST_SIZE_MB=50

# Cache Settings
CACHE_TTL_SECONDS=300
CACHE_KEY_PREFIX=qual_engine_

# Worker Settings
WORKER_CONCURRENCY=4
WORKER_MAX_TASKS_PER_CHILD=1000

# ====================
# Development Tools
# ====================
ENABLE_SWAGGER_UI=true
ENABLE_REDOC=true
ENABLE_DEBUG_TOOLBAR=false
ENABLE_SQL_ECHO=false

# ====================
# Testing Configuration
# ====================
TEST_DATABASE_URL=sqlite:///./test.db
TEST_REDIS_URL=redis://localhost:6379/15
TESTING=false

# ====================
# Deployment Configuration
# ====================
# Docker Settings
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest

# Kubernetes Settings
K8S_NAMESPACE=qual-engine
K8S_REPLICAS=3

# Health Check
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30

# ====================
# Feature Flags
# ====================
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_AI_INSIGHTS=true
FEATURE_VIDEO_PROCESSING=true
FEATURE_COLLABORATION=true
FEATURE_STATISTICAL_ANALYSIS=true
FEATURE_CODE_MIXING=true
FEATURE_CONCEPT_TESTING=true

# ====================
# License & Compliance
# ====================
LICENSE_KEY=
COMPLIANCE_MODE=standard  # standard, gdpr, pdpa
DATA_RESIDENCY_REGION=  # sg, id, my, th, ph, vn