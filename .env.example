# Infra
DATABASE_URL=postgresql+psycopg2://qual:qual@db:5432/qualengine
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:5173

# Auth — CHANGE the secret in production
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM — your own Anthropic key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
MODEL_NAME=claude-sonnet-4-6
STAGE_MAX_TOKENS=1800

# SaaS plan limit
FREE_PLAN_MONTHLY_LIMIT=20

# Set true only for local dev without a Redis broker
CELERY_TASK_ALWAYS_EAGER=false

# --- Phase 1: media + transcription ---
STORAGE_BACKEND=local              # local | s3
MEDIA_DIR=./media
# S3/MinIO (when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=                   # set for MinIO

TRANSCRIPTION_PROVIDER=mock        # mock | deepgram | assemblyai | whisper_local
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
DEFAULT_LANGUAGE=                  # blank = auto-detect
TRANSLATE_TO_ENGLISH=false
